{
  "color": {
    "$type": "color",
    "$description": "The design tool's own UI palette — dark slate, mint accent.",
    "bg":         { "$value": "#15171c" },
    "panel":      { "$value": "#1c1f26" },
    "border":     { "$value": "#2a2e38" },
    "text":       { "$value": "#e7e9ee" },
    "muted":      { "$value": "#8b93a3" },
    "accent":     { "$value": "#6ee7b7" },
    "accent-ink": { "$value": "#08130d" },
    "accent-soft":{ "$value": "#2e4b46" },
    "danger":     { "$value": "#f87171" }
  },
  "font": {
    "$type": "fontFamily",
    "sans": { "$value": "system-ui, -apple-system, 'Segoe UI', sans-serif" },
    "mono": { "$value": "ui-monospace, 'JetBrains Mono', 'SF Mono', Menlo, monospace" }
  },
  "size": {
    "$type": "dimension",
    "$description": "Dense UI scale. step-1 is the base control/body size.",
    "step--1": { "$value": "0.66rem" },
    "step-0":  { "$value": "0.72rem" },
    "step-1":  { "$value": "0.82rem" },
    "step-2":  { "$value": "0.86rem" },
    "step-3":  { "$value": "1.1rem" },
    "step-4":  { "$value": "1.4rem" },
    "step-5":  { "$value": "1.85rem" }
  },
  "leading": {
    "$type": "number",
    "tight":  { "$value": "1.1" },
    "snug":   { "$value": "1.3" },
    "normal": { "$value": "1.5" }
  },
  "tracking": {
    "$type": "dimension",
    "brand": { "$value": "0.02em" },
    "label": { "$value": "0.14em" }
  },
  "space": {
    "$type": "dimension",
    "3xs": { "$value": "0.2rem" },
    "2xs": { "$value": "0.3rem" },
    "xs":  { "$value": "0.4rem" },
    "sm":  { "$value": "0.5rem" },
    "md":  { "$value": "0.7rem" },
    "lg":  { "$value": "1rem" },
    "xl":  { "$value": "1.5rem" },
    "2xl": { "$value": "2rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "4px" },
    "md":   { "$value": "7px" },
    "lg":   { "$value": "9px" },
    "xl":   { "$value": "10px" },
    "tail": { "$value": "3px" },
    "pill": { "$value": "999px" }
  },
  "border": {
    "$type": "dimension",
    "hairline": { "$value": "1px" }
  },
  "shadow": {
    "$type": "shadow",
    "pop":  { "$value": "0 12px 36px rgba(0, 0, 0, 0.4)" },
    "glow": { "$value": "0 0 8px {color.accent}" }
  },
  "control": {
    "$description": "Semantic surfaces for buttons, inputs and selects.",
    "bg":     { "$type": "color", "$value": "{color.bg}" },
    "border": { "$type": "color", "$value": "{color.border}" },
    "focus":  { "$type": "color", "$value": "{color.accent}" }
  },
  "button": {
    "$description": "Primary action — the mint solid button.",
    "bg":    { "$type": "color", "$value": "{color.accent}" },
    "fg":    { "$type": "color", "$value": "{color.accent-ink}" },
    "ghost": { "$type": "color", "$value": "{color.text}" }
  },
  "bubble": {
    "$description": "Chat message surfaces.",
    "user-bg": { "$type": "color", "$value": "{color.accent}" },
    "user-fg": { "$type": "color", "$value": "{color.accent-ink}" },
    "bot-bg":  { "$type": "color", "$value": "{color.panel}" }
  }
}

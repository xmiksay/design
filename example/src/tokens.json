{
  "color": {
    "$type": "color",
    "bg":      { "$value": "#15110e" },
    "surface": { "$value": "#1d1813" },
    "surface-2": { "$value": "#28211b" },
    "ink":     { "$value": "#f4efe6" },
    "muted":   { "$value": "#a89e91" },
    "line":    { "$value": "#3a322c" },
    "accent":  { "$value": "#ef6a3f" },
    "accent-ink": { "$value": "#15110e" },

    "success":         { "$value": "#6cc28b" },
    "success-surface": { "$value": "#1b2a22" },
    "warning":         { "$value": "#e2b24a" },
    "warning-surface": { "$value": "#2d2618" },
    "danger":          { "$value": "#e26a5c" },
    "danger-surface":  { "$value": "#2d1d1b" },
    "info":            { "$value": "#6aa8e0" },
    "info-surface":    { "$value": "#1a2330" }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": "'Fraunces', Georgia, 'Times New Roman', serif" },
    "body":    { "$value": "'Archivo', 'Helvetica Neue', Arial, sans-serif" },
    "mono":    { "$value": "ui-monospace, 'SF Mono', Menlo, monospace" }
  },
  "size": {
    "$type": "dimension",
    "step--1": { "$value": "0.82rem" },
    "step-0":  { "$value": "1rem" },
    "step-1":  { "$value": "1.33rem" },
    "step-2":  { "$value": "1.77rem" },
    "step-3":  { "$value": "2.36rem" },
    "step-4":  { "$value": "3.15rem" }
  },
  "space": {
    "$type": "dimension",
    "xs": { "$value": "0.375rem" },
    "sm": { "$value": "0.625rem" },
    "md": { "$value": "1rem" },
    "lg": { "$value": "1.75rem" },
    "xl": { "$value": "3rem" },
    "2xl": { "$value": "4.5rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "4px" },
    "md":   { "$value": "10px" },
    "lg":   { "$value": "18px" },
    "pill": { "$value": "999px" }
  },
  "border": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "bold":     { "$value": "2px" }
  },
  "button": {
    "$description": "Semantic layer — references the core palette via DTCG aliases.",
    "bg":       { "$type": "color", "$value": "{color.accent}" },
    "fg":       { "$type": "color", "$value": "{color.accent-ink}" },
    "bg-ghost": { "$type": "color", "$value": "{color.ink}" }
  },
  "alert": {
    "$description": "Semantic state surfaces for feedback components.",
    "success-fg": { "$type": "color", "$value": "{color.success}" },
    "success-bg": { "$type": "color", "$value": "{color.success-surface}" },
    "warning-fg": { "$type": "color", "$value": "{color.warning}" },
    "warning-bg": { "$type": "color", "$value": "{color.warning-surface}" },
    "danger-fg":  { "$type": "color", "$value": "{color.danger}" },
    "danger-bg":  { "$type": "color", "$value": "{color.danger-surface}" },
    "info-fg":    { "$type": "color", "$value": "{color.info}" },
    "info-bg":    { "$type": "color", "$value": "{color.info-surface}" }
  }
}

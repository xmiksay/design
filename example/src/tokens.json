{
  "color": {
    "$type": "color",
    "bg":      { "$value": "#f4efe6" },
    "surface": { "$value": "#fbf8f1" },
    "ink":     { "$value": "#1a1714" },
    "muted":   { "$value": "#6f655a" },
    "line":    { "$value": "#ddd3c2" },
    "accent":  { "$value": "#e4572e" },
    "accent-ink": { "$value": "#fbf8f1" }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": "'Fraunces', Georgia, 'Times New Roman', serif" },
    "body":    { "$value": "'Archivo', 'Helvetica Neue', Arial, sans-serif" }
  },
  "size": {
    "$type": "dimension",
    "step-0": { "$value": "1rem" },
    "step-1": { "$value": "1.33rem" },
    "step-2": { "$value": "1.77rem" },
    "step-3": { "$value": "2.36rem" }
  },
  "space": {
    "$type": "dimension",
    "xs": { "$value": "0.375rem" },
    "sm": { "$value": "0.625rem" },
    "md": { "$value": "1rem" },
    "lg": { "$value": "1.75rem" },
    "xl": { "$value": "3rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "10px" }
  },
  "border": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "bold":     { "$value": "2px" }
  },
  "button": {
    "$description": "Semantic layer — references the core palette via DTCG aliases.",
    "bg":       { "$type": "color", "$value": "{color.accent}" },
    "fg":       { "$type": "color", "$value": "{color.accent-ink}" },
    "bg-ghost": { "$type": "color", "$value": "{color.ink}" }
  }
}
